# ──────────────────────────────────────────────────────────────────────────────
# AIP — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Model API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Data Sources ──────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# For local development (SQLite):
DB_PATH=aip.db

# For production (PostgreSQL) — set this to override DB_PATH:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_min_32_characters

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Set to "true" to enforce JWT authentication on all POST endpoints.
# Leave as "false" for local development (backwards-compatible).
REQUIRE_AUTH=false

# ── Encryption ────────────────────────────────────────────────────────────────
# Field-level Fernet encryption for sensitive database columns.
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to disable encryption (development only).
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: ALLOWED_ORIGINS=https://myapp.vercel.app,https://www.myapp.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
# Leave empty to disable Sentry.
SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set in frontend/.env.local (not here).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Agent configuration ───────────────────────────────────────────────────────
# All agents use gpt-5.4 via OPENAI_API_KEY.
# Scheduled jobs run automatically on startup:
#   Orchestrator : daily briefing @ 09:00
#   Marketing    : daily teaser @ 08:30, lead nurture every 2 h
#   Market Intel : pre-market @ 07:00, close summary @ 16:30
#   Customer     : daily check @ 10:00
#   Analytics    : KPI report @ 08:00, anomaly check every 4 h
